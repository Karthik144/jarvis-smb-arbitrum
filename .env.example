# Reclaim Protocol Application ID
# Get from: https://dev.reclaimprotocol.org/
RECLAIM_APP_ID=your_app_id_here

# Reclaim Protocol Application Secret
# Get from: https://dev.reclaimprotocol.org/
RECLAIM_APP_SECRET=your_app_secret_here

# Amazon tracking number to verify
# Example format: TBA326330626265
TRACKING_NUMBER=TBA326330626265
