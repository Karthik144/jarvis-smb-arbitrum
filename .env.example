# Privy Configuration
NEXT_PUBLIC_PRIVY_APP_ID=example

# Reclaim Protocol Configuration
NEXT_PUBLIC_RECLAIM_APP_ID=example
RECLAIM_APP_SECRET=example

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Arbitrum Configuration
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arbitrum-sepolia.infura.io/v3/your_infura_key
NEXT_PUBLIC_PAYMENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
PRIVATE_KEY=example

# Environment
NEXT_PUBLIC_ENVIRONMENT=development
